{
  "manifest_version": 3,
  "name": "Dashboard — New Tab",
  "version": "1.1.0",
  "description": "A modular, moveable dashboard for your new tab page.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'"
  },
  "action": {
    "default_title": "Dashboard"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
